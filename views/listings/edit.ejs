<% layout("/layouts/boilerPlate") %>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <form method="POST" action="/listings/<%=listing._id%>?_method=PUT">
      <h3 class="fw-bold text-center mb-4">Edit Your listing</h3>

      <div class="mb-3">
        <label class="form-label fw-semibold mb-1" for="title">Title</label>
        <input
          class="shadow-sm rounded-3 form-control"
          name="listing[title]"
          value="<%= listing.title %>"
          type="text"
        />
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold mb-1" for="description"
          >Description</label
        >
        <textarea
          class="form-control shadow-sm rounded-3"
          style="height: 100px"
          name="listing[description]"
        >
        <%= listing.description %> 
    </textarea
        >
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold mb-1" for="location"
          >Location</label
        >
        <input
          class="form-control shadow-sm rounded-3"
          name="listing[location]"
          value="<%= listing.location %>"
          type="text"
        />
      </div>

      <div class="row">
        <div class="mb-3 col-md-6">
          <label class="form-label fw-semibold mb-1" for="price">Price</label>
          <input
            class="form-control shadow-sm rounded-3"
            name="listing[price]"
            value="<%= listing.price %>"
            type="number"
          />
        </div>
        <div class="mb-3 col-md-6">
          <label class="form-label fw-semibold mb-1" for="country"
            >Country</label
          >
          <input
            class="form-control shadow-sm rounded-3"
            name="listing[country]"
            value="<%= listing.country %>"
            type="text"
          />
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold mb-1" for="image">Image URL</label>
        <input
          class="form-control  "
          name="listing[image][url]"
          value="<%= listing.image.url %>"
          type="text"
        />
      </div>

      <div class="mt-3 d-grid gap-2 col-6 mx-auto">
        <button type="submit" class="btn btn-success w-100 py-2">
          Save Changes
        </button>
      </div>

      <br />
    </form>
  </div>
</div>
