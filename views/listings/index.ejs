<% layout("/layouts/boilerPlate") %>
<div id="filters-container">
  <button id="leftBtn">←</button>


  <div id="filters">
   
    <a href="/listings?category=Rooms" class="filter-link">
    <div class="filters">
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Rooms</p>
    </div>
  </a>

  <a href="/listings?category=Trending" class="filter-link">
    <div class="filters">
      <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p>
    </div>
  </a>

  <a href="/listings?category=Mountain" class="filter-link">
    <div class="filters">
      <div><i class="fa-solid fa-mountain-city"></i></div>
      <p>Mountain</p>
    </div>
  </a>

  <a href="/listings?category=Lakefront" class="filter-link">
    <div class="filters">
      <div><i class="fa-solid fa-water"></i></div>
      <p>Lakefront</p>
    </div>
  </a>

  <a href="/listings?category=Beach" class="filter-link">
    <div class="filters">
      <div><i class="fa-solid fa-umbrella-beach"></i></div>
      <p>Beach</p>
    </div>
  </a>

  <a href="/listings?category=Arctic" class="filter-link">
    <div class="filters">
      <div><i class="fa-solid fa-snowflake"></i></div>
      <p>Arctic</p>
    </div>
  </a>

  <a href="/listings?category=Forest" class="filter-link">
    <div class="filters">
      <div><i class="fa-solid fa-tree"></i></div>
      <p>Forest</p>
    </div>
  </a>

  <a href="/listings?category=Camping" class="filter-link">
    <div class="filters">
      <div><i class="fa-solid fa-campground"></i></div>
      <p>Camping</p>
    </div>
  </a>

  <a href="/listings?category=Pools" class="filter-link">
    <div class="filters">
      <div><i class="fa-solid fa-person-swimming"></i></div>
      <p>Pools</p>
    </div>
  </a>

  <a href="/listings?category=City View" class="filter-link">
    <div class="filters">
      <div><i class="fa-solid fa-city"></i></div>
      <p>City View</p>
    </div>
  </a>

  <a href="/listings?category=Luxury" class="filter-link">
    <div class="filters">
      <div><i class="fa-solid fa-gem"></i></div>
      <p>Luxury</p>
    </div>
  </a>

  <a href="/listings?category=Pets" class="filter-link">
    <div class="filters">
      <div><i class="fa-solid fa-paw"></i></div>
      <p>Pets</p>
    </div>
  </a>

  <a href="/listings?category=Boats" class="filter-link">
    <div class="filters">
      <div><i class="fa-solid fa-ship"></i></div>
      <p>Boats</p>
    </div>
  </a>

  </div>
  <button id="rightBtn">→</button>

  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">
        Show prices with taxes
      </label>
    </div>
  </div>

</div>


<!-- <h1 class="fw-bold text-center mb-4">ALL LISTINGS</h1> -->
<div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-1">
  <% for (let listing of allListings){ %>
  <div class="card card-listing cols">
    <a href="/listings/<%= listing._id %>">
      <img
        src="<%= listing.image.url %>"
        class="card-img-top"
        alt="listing-img"
        style="height: 20rem"
      />
      <div class="card-img-overlay">
        <h5 class="card-title"></h5>
      </div>
      <div class="card-body">
        <p class="card-text">
          <b><%= listing.title %></b> <br />
          &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") :"N/A" %> /night
         <i class="tax-info"> &nbsp;  &nbsp;+18% GST</i>
        </p>
      </div>
    </a>
  </div>
  <%}%>
</div>

 <script>
  let taxSwitch = document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("click", ()=>{
    let taxInfo = document.getElementsByClassName("tax-info");
    for(info of taxInfo){
      if(info.style.display != "inline"){
        info.style.display = "inline";
      }else{
        info.style.display = "none";
      }
    }
    
  });

  const filters = document.querySelector("#filters");

document.querySelector("#leftBtn").onclick = () => {
    filters.scrollBy({ left: -180, behavior: "smooth" });
};

document.querySelector("#rightBtn").onclick = () => {
    filters.scrollBy({ left: 180, behavior: "smooth" });
};
 </script>