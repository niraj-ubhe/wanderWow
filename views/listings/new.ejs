<% layout("/layouts/boilerPlate") %>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <h3 class="fw-bold text-center mb-4">Create NEW Listing</h3>

    <form
      method="POST"
      action="/listings"
      class="needs-validation"
      novalidate
      enctype="multipart/form-data"
    >
      <div class="mb-3">
        <label for="Title" class="form-label fw-semibold mb-1">Title</label>
        <input
          class="form-control shadow-sm rounded-3"
          name="listing[title]"
          type="text"
          required
        />
        <div class="invalid-feedback">Enter valid title!</div>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold mb-1">Category</label>

        <select name="listing[category]" class="form-select">
          <option>Rooms</option>
          <option>Trending</option>
          <option>Mountain</option>
          <option>Lakefront</option>
          <option>Beach</option>
          <option>Arctic</option>
          <option>Forest</option>
          <option>Camping</option>
          <option>Pools</option>
          <option>City View</option>
          <option>Luxury</option>
          <option>Pets</option>
          <option>Boats</option>
        </select>
      </div>

      <div class="mb-3">
        <label for="description" class="fw-semibold mb-1 form-label"
          >Description</label
        >
        <textarea
          style="height: 100px; resize: none"
          name="listing[description]"
          type="text"
          class="form-control shadow-sm rounded-3"
          required
        ></textarea>
        <div class="invalid-feedback">Enter valid description!</div>
      </div>

      <div class="mb-3">
        <label for="location" class="form-label fw-semibold mb-1"
          >Location</label
        >
        <input
          class="form-control shadow-sm rounded-3"
          name="listing[location]"
          type="text"
          required
        />
        <div class="invalid-feedback">Enter valid location!</div>
      </div>

      <div class="row">
        <div class="mb-3 col-md-6">
          <label for="price" class="form-label fw-semibold mb-1">Price</label>
          <input
            class="form-control shadow-sm rounded-3"
            name="listing[price]"
            required
          />
          <div class="invalid-feedback">Enter valid price!</div>
        </div>

        <div class="mb-3 col-md-6">
          <label for="country" class="form-label fw-semibold mb-1"
            >Country</label
          >
          <input
            name="listing[country]"
            class="form-control shadow-sm rounded-3"
            type="text"
            required
          />
          <div class="invalid-feedback">Enter valid country!</div>
        </div>
      </div>

      <div class="mb-3">
        <label for="image" class="form-label fw-semibold mb-1"
          >Upload Image</label
        >
        <input
          class="form-control shadow-sm rounded-3"
          name="listing[image]"
          type="file"
          required
        />
      </div>

      <div class="mt-3 d-grid gap-2 col-6 mx-auto">
        <button type="submit" class="btn btn-success w-100 py-2">
          Add New Listing
        </button>
      </div>

      <br /><br />
    </form>
  </div>
</div>
<script src="/js/script.js"></script>
