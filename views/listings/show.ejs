<% layout("/layouts/boilerPlate") %>

<div class="row mt-4">
  <div class="col-8 offset-2">
    <h3 class="card-title mb-2"><%= listing.title %></h3>

    <div>
      <img
        class="show-img card-img-top mb-3"
        alt="listing-image"
        src="<%= listing.image.url %>"
      />

      <div class="card-body">
        <p class="card-text mb-2">
          Owned By: <i><%= listing.owner.username %></i>
        </p>

        <p class="card-text mb-1">
          <%= listing.description %>
        </p>

        <p class="card-text mb-1">
          <%= listing.location %>, <%= listing.country %>
        </p>

        <p class="card-text fw-bold fs-5">
          &#8377; <%= listing.price.toLocaleString("en-IN") %>/night
        </p>

        <% if(currUser && listing.owner._id.equals(currUser._id)) { %>

        <div class="row mt-3 mb-4">
          <div class="col-5 offset-1">
            <form
              method="GET"
              action="/listings/<%= listing._id %>/edit"
            >
              <button
                type="submit"
                class="btn btn-outline-primary w-100"
              >
                Edit Listing
              </button>
            </form>
          </div>

          <div class="col-5">
            <form
              method="POST"
              action="/listings/<%= listing._id %>?_method=DELETE"
            >
              <button
                type="submit"
                class="btn btn-outline-danger w-100"

                <% if(currUser) { %>
                  onclick="return confirm('Are you sure you want to delete this listing?');"
                <% } %>
              >
                Delete Listing
              </button>
            </form>
          </div>
        </div>

        <% } %>
      </div>

      <hr />
     
      <div class="mb-3 mt-3">
         <%if(currUser){%>
        <h4>Leave a Review</h4>

        <form
          action="/listings/<%= listing.id %>/reviews"
          method="POST"
          class="needs-validation"
          novalidate
        >
          <div class="mb-3">
            <label for="rating" class="form-label">
              Rating
            </label>

            <input
              type="range"
              min="1"
              max="5"
              name="review[rating]"
              id="rating"
              class="form-range"
            />
          </div>

          <div class="mb-3">
            <label for="comment" class="form-label">
              Comments
            </label>

            <textarea
              name="review[comment]"
              id="comment"
              cols="30"
              rows="5"
              class="form-control"
              required
            ></textarea>

            <div class="invalid-feedback">
              Please add some comments for review
            </div>
          </div>

          <button class="btn btn-outline-dark mb-3">
            Submit
          </button>
        </form>

        <hr />
         <% } %>

        <h4 class="mb-3">All Reviews</h4>

        <div class="row g-3">
          <% for(review of listing.reviews) { %>

          <div class="col-md-6">
            <div class="card shadow-sm h-100">
              <div class="card-body">
                <h5 class="card-title mb-2">
                  <%= review.author.username %>
                </h5>

                <p class="card-text">
                  <%= review.comment %>
                </p>

                <p class="card-text text-muted">
                  Rating: ⭐ <%= review.rating %>/5
                </p>

                <form
                  action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                  method="POST"
                >
                  <button class="btn btn-sm btn-dark mb-2">
                    Delete
                  </button>
                </form>
              </div>
            </div>
          </div>

          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>