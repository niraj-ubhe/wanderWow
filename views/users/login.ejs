<% layout("/layouts/boilerPlate") %>

<div class="row mt-3">
  <h1 class="col-6 offset-3">Login</h1>

  <div class="col-6 offset-3 mt-2">
    <form action="/login" method="POST" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="username" class="form-label fw-semibold mb-1"
          >Username</label
        >
        <input
          class="form-control shadow-sm rounded-3"
          name="username"
          id="username"
          type="text"
          required
        />
      </div>

      <div class="mb-3">
        <label for="password" class="form-label fw-semibold mb-1"
          >Password</label
        >
        <input
          class="form-control shadow-sm rounded-3"
          name="password"
          id="password"
          type="password"
          required
        />
      </div>
      <button class="btn btn-success offset-5 mt-2 mb-2">Login</button>
    </form>
  </div>
</div>
